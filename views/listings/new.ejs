<% layout("layouts/boilerplate") %>

<div class="row mt-4">
  <div class="col-md-8 offset-md-2">
    <h3 class="mb-4">Create a New Listing</h3>

    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
      
      <!-- Title -->
      <div class="mb-3">
        <label class="form-label">Title</label>
        <input name="listing[title]" class="form-control" required>
      </div>

      <!-- Description -->
      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea name="listing[description]" class="form-control" required></textarea>
      </div>

      <!-- Image -->
      <div class="mb-3">
        <label class="form-label">Upload Image</label>
        <input name="listing[image]" type="file" class="form-control" required>
      </div>

      <!-- Category -->
      <div class="mb-3">
        <label class="form-label">Category</label>
        <select name="listing[category]" class="form-select" required>
          <option value="">--Select Category--</option>
          <option value="trending">Trending</option>
          <option value="rooms">Rooms</option>
          <option value="iconic-cities">Iconic Cities</option>
          <option value="mountains">Mountains</option>
          <option value="castles">Castles</option>
          <option value="amazing-pools">Amazing Pools</option>
          <option value="camping">Camping</option>
          <option value="farms">Farms</option>
          <option value="arctic">Arctic</option>
        </select>
      </div>

      <!-- Price, Country, Location in one row -->
      <div class="row">
        <div class="col-md-4 mb-3">
          <label class="form-label">Price</label>
          <input name="listing[price]" class="form-control" required>
        </div>

        <div class="col-md-4 mb-3">
          <label class="form-label">Country</label>
          <input name="listing[country]" class="form-control" required>
        </div>

        <div class="col-md-4 mb-3">
          <label class="form-label">Location</label>
          <input name="listing[location]" class="form-control" required>
        </div>
      </div>

      <!-- Button -->
      <button class="btn btn-dark w-100">Add</button>

    </form>
  </div>
</div>