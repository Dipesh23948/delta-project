<% layout("layouts/boilerplate") %>

<style>
  #filters-wrapper {
    display: flex;
    align-items: center;
    border-bottom: 1px solid #e0e0e0;
    padding: 0.75rem 0;
    margin-bottom: 1rem;
    gap: 1rem;
  }

  #filters {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    gap: 1.8rem;
    flex: 1;
    scrollbar-width: none;
  }

  #filters::-webkit-scrollbar {
    display: none;
  }

  .filter {
    text-align: center;
    opacity: 0.6;
    text-decoration: none;
    color: black;
    flex-shrink: 0;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid transparent;
    transition: opacity 0.2s;
  }

  .filter:hover {
    opacity: 1;
  }

  .filter.active {
    opacity: 1;
    border-bottom: 2px solid black;
  }

  .filter i {
    font-size: 1.3rem;
    display: block;
    margin-bottom: 0.2rem;
  }

  .filter p {
    font-size: 0.72rem;
    margin-bottom: 0;
    white-space: nowrap;
  }

  .tax-info {
    display: none;
  }

  .tax-toggle {
    flex-shrink: 0;
    border: 1px solid #ccc;
    border-radius: 1rem;
    padding: 0.4rem 1rem;
    display: flex;
    align-items: center;
    font-size: 0.85rem;
    white-space: nowrap;
  }

  @media (max-width: 576px) {
    #filters-wrapper {
      flex-wrap: wrap;
    }
    #filters {
      order: 1;
      width: 100%;
    }
    .tax-toggle {
      order: 2;
      width: 100%;
      justify-content: center;
    }
  }
</style>

<div id="filters-wrapper">
  <div id="filters">
    <a href="/listings?category=trending" class="filter" data-category="trending">
      <i class="fa-solid fa-fire"></i>
      <p>Trending</p>
    </a>
    <a href="/listings?category=rooms" class="filter" data-category="rooms">
      <i class="fa-solid fa-bed"></i>
      <p>Rooms</p>
    </a>
    <a href="/listings?category=iconic-cities" class="filter" data-category="iconic-cities">
      <i class="fa-solid fa-mountain-city"></i>
      <p>Iconic Cities</p>
    </a>
    <a href="/listings?category=mountains" class="filter" data-category="mountains">
      <i class="fa-solid fa-mountain"></i>
      <p>Mountains</p>
    </a>
    <a href="/listings?category=castles" class="filter" data-category="castles">
      <i class="fa-brands fa-fort-awesome"></i>
      <p>Castles</p>
    </a>
    <a href="/listings?category=amazing-pools" class="filter" data-category="amazing-pools">
      <i class="fa-solid fa-person-swimming"></i>
      <p>Amazing Pools</p>
    </a>
    <a href="/listings?category=camping" class="filter" data-category="camping">
      <i class="fa-solid fa-campground"></i>
      <p>Camping</p>
    </a>
    <a href="/listings?category=farms" class="filter" data-category="farms">
      <i class="fa-solid fa-cow"></i>
      <p>Farms</p>
    </a>
    <a href="/listings?category=arctic" class="filter" data-category="arctic">
      <i class="fa-solid fa-snowflake"></i>
      <p>Arctic</p>
    </a>
  </div>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch mb-0">
      <input class="form-check-input" type="checkbox" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">
        Display Total after taxes
      </label>
    </div>
  </div>
</div>

<!-- LISTINGS -->
<div id="listing-container" class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
  <% for (let listing of allListings) { %>
    <div class="col">
      <a href="/listings/<%= listing._id %>" class="listing-links">
        <div class="card listing-card h-100">
          <img src="<%= listing.image.url %>" class="card-img-top" style="height: 20rem; object-fit: cover;">
          <div class="card-body">
            <p class="card-text"><b><%= listing.title %></b></p>
            &#8377; <%= listing.price.toLocaleString("en-IN") %> /night
            <i class="tax-info">&nbsp; +18% GST</i>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>

<script>
  let taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click", () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for (let info of taxInfo) {
      info.style.display = info.style.display === "inline" ? "none" : "inline";
    }
  });
</script>

<script>
  const filters = document.querySelectorAll(".filter");
  filters.forEach(filter => {
    filter.addEventListener("click", async (e) => {
      e.preventDefault();
      const category = filter.dataset.category;
      const res = await fetch(`/listings/filter?category=${category}`);
      const data = await res.json();
      const container = document.getElementById("listing-container");
      container.innerHTML = "";
      if (data.length === 0) {
        container.innerHTML = "<h3 class='mt-3'>No listings found</h3>";
        return;
      }
      data.forEach(listing => {
        const card = `
          <div class="col">
            <a href="/listings/${listing._id}" class="listing-links">
              <div class="card listing-card h-100">
                <img src="${listing.image.url}" class="card-img-top" style="height: 20rem; object-fit: cover;">
                <div class="card-body">
                  <p class="card-text"><b>${listing.title}</b></p>
                  &#8377; ${listing.price.toLocaleString("en-IN")} /night
                  <i class="tax-info">&nbsp; +18% GST</i>
                </div>
              </div>
            </a>
          </div>
        `;
        container.innerHTML += card;
      });
      filters.forEach(f => f.classList.remove("active"));
      filter.classList.add("active");
    });
  });
</script>
